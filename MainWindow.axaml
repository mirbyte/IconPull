<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="IconPull.MainWindow"
        Title="IconPull" Width="920" Height="485" MinWidth="740" MinHeight="465"
        WindowStartupLocation="CenterScreen" UseLayoutRounding="True"
        Icon="/Assets/icon.ico"
        Background="#f5f7fb" FontFamily="Inter, Segoe UI, Arial">

    <Grid Margin="20,18,20,16" RowDefinitions="Auto,*">

        <TextBlock Grid.Row="0" Text="IconPull" FontSize="22" FontWeight="Bold"
                   Foreground="#111827" Margin="0,0,0,14"/>

        <Grid Grid.Row="1" ColumnDefinitions="3*,2*">

            <Grid Grid.Column="0" RowDefinitions="*,72" Margin="0,0,7,0">
                <Border Grid.Row="0" Classes="card" Padding="16,14">
                    <Grid RowDefinitions="*,Auto">
                        <Border x:Name="DropZoneBorder" Grid.Row="0"
                                Background="#f8fafc" BorderBrush="#c5d0e0" BorderThickness="2"
                                CornerRadius="12" ClipToBounds="True" DragDrop.AllowDrop="True"
                                Margin="0,0,0,10" MinHeight="140">
                            <Grid>
                                <StackPanel x:Name="FileDisplay" IsVisible="False"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Spacing="12" Margin="16">
                                    <Border Background="White" BorderBrush="#e5e7eb" BorderThickness="1"
                                            CornerRadius="10" Padding="16" HorizontalAlignment="Center">
                                        <Image x:Name="DropZonePreviewImage" Stretch="Uniform"
                                               MaxWidth="160" MaxHeight="160" MinWidth="64" MinHeight="64"/>
                                    </Border>
                                    <TextBlock x:Name="FilePathText" TextTrimming="CharacterEllipsis"
                                               Foreground="#111827" FontSize="13" HorizontalAlignment="Center"
                                               MaxWidth="360" TextAlignment="Center"/>
                                </StackPanel>

                                <StackPanel x:Name="EmptyState" IsHitTestVisible="False"
                                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                    <TextBlock Text="&#128194;" FontSize="32" HorizontalAlignment="Center" Opacity="0.45"/>
                                    <TextBlock Text="Drop a file here" FontSize="15" FontWeight="SemiBold"
                                               Foreground="#374151" HorizontalAlignment="Center"/>
                                    <TextBlock Text=".exe  .dll  .ico  .cpl  .scr  .ocx  .icl  .mun"
                                               FontSize="12" Foreground="#9ca3af" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                            <Button Classes="secondary" Content="Choose file" Click="OnChooseFileClicked"/>
                            <Button Classes="secondary" Content="Clear" Click="OnClearClicked"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Classes="card" Padding="14,12" Margin="0,14,0,0">
                    <Grid RowDefinitions="Auto,*">
                        <Button Classes="secondary" Content="Clear log" HorizontalAlignment="Right"
                                Padding="10,4" FontSize="12" Margin="0,0,0,6" Click="OnClearLogClicked"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <TextBox x:Name="LogTextBox" Classes="log" IsReadOnly="True"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     BorderThickness="0" Background="Transparent"
                                     FontFamily="Consolas, Cascadia Mono, monospace"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Classes="card" Padding="16,14" Margin="7,0,0,0">
                <Grid RowDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Row="0" Spacing="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Folder" FontSize="13" Foreground="#374151"/>
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBox x:Name="OutputEdit" Grid.Column="0" PlaceholderText="Choose output folder..." Margin="0,0,8,0"/>
                                <Button Grid.Column="1" Classes="secondary" Content="Browse" Click="OnBrowseClicked" Margin="0,0,8,0"/>
                                <Button Grid.Column="2" Classes="secondary" Content="Open" Click="OnOpenFolderClicked"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Icon size (px)" FontSize="13" Foreground="#374151"/>
                            <ComboBox x:Name="SizeCombo" SelectedIndex="3" HorizontalAlignment="Left" MinWidth="120"
                                      SelectionChanged="OnSizeChanged">
                                <ComboBoxItem>64</ComboBoxItem>
                                <ComboBoxItem>128</ComboBoxItem>
                                <ComboBoxItem>256</ComboBoxItem>
                                <ComboBoxItem>512</ComboBoxItem>
                                <ComboBoxItem>1024</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Export formats" FontSize="13" Foreground="#374151"/>
                            <StackPanel Spacing="4">
                                <CheckBox x:Name="ShellCheck" Content="Shell-rendered PNG" IsChecked="True"/>
                                <CheckBox x:Name="RawIcoCheck" Content="Raw embedded ICO" IsChecked="True"/>
                                <CheckBox x:Name="RawPngCheck" Content="Raw best PNG" IsChecked="True"/>
                                <CheckBox x:Name="ScaleupCheck" Content="Allow Shell upscale"
                                          IsCheckedChanged="OnScaleupChanged"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Spacing="8">
                        <TextBlock x:Name="StatusText" Text="Ready." FontSize="13" Foreground="#6b7280"/>
                        <Button x:Name="ExtractButton" Classes="primary" Content="Extract icons"
                                HorizontalAlignment="Stretch" Click="OnExtractClicked"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
